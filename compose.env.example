# Optional: copy to `.env` in the repo root so `docker compose` picks up variables.
# Values here are substituted into docker-compose.yml only (not inside containers unless passed explicitly).

# Public API base URL baked into the Next.js build. Must be reachable from the user's browser
# (use localhost and published ports when testing compose on one machine, or your real public API URL in production).
NEXT_PUBLIC_API_URL=http://localhost:4000/api
