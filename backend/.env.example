# Copy to .env and adjust. Never commit .env.
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/bellavault
JWT_SECRET=replace-with-a-long-random-secret-in-production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Optional — see README (Backend environment variables). Dangerous in production if set to true.
# AUTH_RETURN_OTP_IN_RESPONSE=false

# Optional — GoldAPI.io / app.goldapi.net for live XAU, XAG, XPT, XPD spot (USD). Never commit real keys.
# GOLDAPI_API_KEY=
# Optional base URL if your provider uses a different host (default https://app.goldapi.net).
# GOLDAPI_BASE_URL=https://app.goldapi.net
