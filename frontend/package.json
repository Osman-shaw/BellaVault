{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "cross-env IS_WEBPACK_TEST=1 NEXT_DISABLE_SWC_NATIVE=1 node ./node_modules/next/dist/bin/next dev --webpack",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && cross-env IS_WEBPACK_TEST=1 NEXT_DISABLE_SWC_NATIVE=1 node ./node_modules/next/dist/bin/next dev --webpack",
    "build": "cross-env NEXT_DISABLE_SWC_NATIVE=1 next build --webpack",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.2"
  }
}
